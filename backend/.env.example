# Prefer 5001 on macOS — port 5000 is often taken by AirPlay Receiver (proxied POSTs can get 403).
PORT=5001
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/flowmind
JWT_SECRET=replace-with-a-secure-random-secret
GEMINI_API_KEY=replace-with-your-gemini-api-key
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
GMAIL_CLIENT_ID=replace-with-your-google-oauth-client-id
GMAIL_CLIENT_SECRET=replace-with-your-google-oauth-client-secret
# Must match Google Cloud "Authorized redirect URIs" exactly (no trailing slash)
GOOGLE_REDIRECT_URI=http://localhost:5001/api/gmail/callback
# Legacy alias — used only if GOOGLE_REDIRECT_URI is unset
GMAIL_REDIRECT_URI=
GMAIL_REFRESH_TOKEN=replace-with-your-google-refresh-token
GMAIL_ACCESS_TOKEN=optional-initial-access-token
NOTIFICATION_EMAIL=optional-notification-recipient@example.com
ENCRYPTION_KEY=replace-with-a-32-byte-secret
